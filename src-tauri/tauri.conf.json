{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flint",
  "version": "0.1.0",
  "identifier": "com.flint.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flint",
        "width": 1000,
        "height": 700,
        "minWidth": 640,
        "minHeight": 440,
        "decorations": true,
        "resizable": true,
        "center": true,
        "backgroundColor": "#1e1e1e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Strike focus.",
    "longDescription": "Open-source, local-first, keyboard-driven, plugin-extensible timer for focused work."
  }
}
